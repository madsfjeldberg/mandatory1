  "item": [
    {
      "name": "cpr",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "",
              "pm.test(\"Response shape is correct\", function() {",
              "    pm.response.to.have.jsonSchema({",
              "        \"type\": \"object\",",
              "        \"properties\": {",
              "            \"CPR\": {",
              "                \"type\": \"string\"",
              "            }",
              "        }",
              "    })",
              "})",
              "",
              "pm.test(\"CPR value is correct\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.CPR).to.exist;",
              "    pm.expect(response.CPR).to.be.a('string');",
              "    pm.expect(response.CPR).to.have.lengthOf(10);",
              "    pm.expect(response.CPR).to.match(/^\\d+$/); // Check if it contains only numbers",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
