    {
      "name": "name-gender-dob",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "const response = pm.response.json();\r",
              "const fields = [\"firstName\", \"lastName\", \"gender\", \"birthDate\"];\r",
              "fields.forEach(field => {\r",
              "    pm.test(`${field} should exist`, () => {\r",
              "        pm.expect(response).to.have.property(field);\r",
              "    });\r",
              "\r",
              "    pm.test(`${field} should be a string`, () => {\r",
              "        pm.expect(response[field]).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(`${field} should not be empty`, () => {\r",
              "        pm.expect(response[field].trim().length).to.be.above(0);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
